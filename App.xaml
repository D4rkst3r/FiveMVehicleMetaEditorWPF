<Application x:Class="FiveMVehicleMetaEditorWPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:FiveMVehicleMetaEditorWPF"
             xmlns:conv="clr-namespace:FiveMVehicleMetaEditorWPF.Core.Converters"
             xmlns:System="clr-namespace:System;assembly=mscorlib"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Converters -->
        <conv:BoolToVisibilityConverter x:Key="BoolToVisConverter"/>
        <conv:BoolToVisibilityInverseConverter x:Key="BoolToVisInverseConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

        <!-- Modern FiveM Theme - Orange & Cyan (Dynamic for live theme changes) -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF9500" />
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#E67E00" />
        <SolidColorBrush x:Key="PrimaryLightBrush" Color="#FFB84D" />

        <SolidColorBrush x:Key="SecondaryBrush" Color="#00D4FF" />
        <SolidColorBrush x:Key="SecondaryDarkBrush" Color="#00A3CC" />
        <SolidColorBrush x:Key="SecondaryLightBrush" Color="#66DDFF" />

        <SolidColorBrush x:Key="DangerBrush" Color="#FF4444"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#FFB84D"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#44DD44"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#00D4FF"/>

        <!-- Background Brushes - Modern Dark Navy -->
        <SolidColorBrush x:Key="DarkBgBrush" Color="#0F1419"/>
        <SolidColorBrush x:Key="DarkerBgBrush" Color="#0A0D12"/>
        <SolidColorBrush x:Key="SecondaryBgBrush" Color="#1A2332"/>
        <SolidColorBrush x:Key="TertiaryBgBrush" Color="#242E3A"/>

        <!-- Text Brushes -->
        <SolidColorBrush x:Key="LightTextBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="WhiteTextBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GrayTextBrush" Color="#888888"/>

        <!-- Settings Resources (can be changed at runtime) -->
        <System:Double x:Key="DefaultFontSize">12</System:Double>
        <System:Boolean x:Key="CompactMode">false</System:Boolean>

        <!-- Button Style -->
        <Style TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteTextBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource SecondaryLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource SecondaryDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Command Button Style (Load, Save, Export) - Orange -->
        <Style x:Key="CommandButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteTextBrush}"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar Style for Dark Theme -->
        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Width" Value="16"/>
        </Style>

        <!-- ScrollViewer Style -->
        <Style TargetType="{x:Type ScrollViewer}">
            <Setter Property="Background" Value="{DynamicResource SecondaryBgBrush}"/>
        </Style>

        <!-- Global Window Style -->
        <Style TargetType="{x:Type Window}">
            <Setter Property="Background" Value="{DynamicResource DarkBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource WhiteTextBrush}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

    </Application.Resources>
</Application>

