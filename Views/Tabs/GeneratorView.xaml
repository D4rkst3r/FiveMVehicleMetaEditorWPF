<UserControl x:Class="FiveMVehicleMetaEditorWPF.Views.Tabs.GeneratorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="{DynamicResource SecondaryBgBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding GenerateCommand}" Content="⚙️ Generate" Width="110" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding ResetCommand}" Content="🔄 Reset" Width="80" Style="{StaticResource CommandButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="20">
                <TextBlock Text="🔧 Vehicle Generator" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,5"/>
                <TextBlock Text="Create a new vehicles.meta entry from scratch"
                           Foreground="{DynamicResource GrayTextBrush}" Margin="0,0,0,20"/>

                <Border Background="{DynamicResource SecondaryBgBrush}" Padding="20" CornerRadius="4" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Required Fields" Grid.ColumnSpan="2"
                                   FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Model Name: *"
                                   Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                 Padding="8,5" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Handling ID: *"
                                   Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding HandlingId, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                 Padding="8,5" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="3" Text="Optional Fields" Grid.ColumnSpan="2"
                                   FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,10,0,10"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="TXD Name:"
                                   Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding TxdName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                 Padding="8,5" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Game Name:"
                                   Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding GameName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                 Padding="8,5" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Make Name:"
                                   Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding VehicleMakeName, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                 Padding="8,5" Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="7" Grid.Column="0" Text="Vehicle Class:"
                                   Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,0,0,8"/>
                        <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,0,0,8">
                            <TextBox Text="{Binding VehicleClass, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="8,5"/>
                            <TextBlock Text="Examples: VC_SEDAN, VC_SUV, VC_SPORTS, VC_SUPER, VC_MUSCLE, VC_TRUCK, VC_MOTORCYCLE, VC_MILITARY, VC_EMERGENCY"
                                       TextWrapping="Wrap"
                                       Foreground="{DynamicResource GrayTextBrush}" FontSize="10" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource GrayTextBrush}" FontSize="10"
                           Text="* Required fields. TXD Name defaults to Model Name if empty. Click Generate to save the vehicles.meta file."/>
            </StackPanel>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource TertiaryBgBrush}" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource GrayTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
