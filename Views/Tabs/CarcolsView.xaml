<UserControl x:Class="FiveMVehicleMetaEditorWPF.Views.Tabs.CarcolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource SecondaryBgBrush}" Padding="8,6">
            <WrapPanel Orientation="Horizontal">
                <Button Command="{Binding LoadCommand}" Content="Load" Width="65" Style="{StaticResource CommandButtonStyle}"
                        ToolTip="Load carcols.meta"/>
                <Button Command="{Binding SaveCommand}" Content="Save" Width="65" Style="{StaticResource CommandButtonStyle}"
                        ToolTip="Save carcols.meta (auto-backup created)"/>
                <Button Command="{Binding ExportCommand}" Content="Export" Width="65" Style="{StaticResource CommandButtonStyle}"
                        ToolTip="Export as JSON"/>
                <Separator Width="8"/>
                <Button Command="{Binding AddKitCommand}" Content="+ Add Kit" Width="80" Style="{StaticResource CommandButtonStyle}"
                        ToolTip="Add a new empty kit with auto-incremented ID"/>
                <Button Command="{Binding DeleteKitCommand}" Content="Delete Kit" Width="80" Style="{StaticResource CommandButtonStyle}"
                        ToolTip="Delete the selected kit"/>
                <Separator Width="8"/>
                <TextBlock Text="{Binding CarcolEntries.Count}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold" FontSize="13"/>
                <TextBlock Text=" kits" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Left: Kit List -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SecondaryBgBrush}" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Mod Kits" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="8,8,8,5"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CarcolEntries}"
                         SelectedItem="{Binding SelectedEntry}"
                         Background="{DynamicResource DarkBgBrush}"
                         Foreground="{DynamicResource LightTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{DynamicResource LightTextBrush}" Padding="2" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Kit Details + Edit -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SecondaryBgBrush}" Margin="5" Padding="12">
            <Grid>
                <!-- Empty state -->
                <StackPanel Visibility="{Binding SelectedEntry, Converter={StaticResource BoolToVisInverseConverter}}">
                    <TextBlock Text="Carcols Editor" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="Select a mod kit from the list to view and edit its details."
                               FontSize="11" Foreground="{DynamicResource GrayTextBrush}" TextWrapping="Wrap"/>
                    <TextBlock Text="Use + Add Kit to create a new kit."
                               FontSize="11" Foreground="{DynamicResource GrayTextBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Kit details and edit panel -->
                <ScrollViewer Visibility="{Binding SelectedEntry, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <!-- Header -->
                        <TextBlock Text="{Binding SelectedEntry}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                        <!-- Edit fields -->
                        <Border Background="{DynamicResource DarkBgBrush}" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Edit Kit" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding EditKitName, UpdateSourceTrigger=PropertyChanged}"
                                             Background="{DynamicResource SecondaryBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                             Padding="5,3" BorderThickness="1" BorderBrush="#555" Margin="0,3"
                                             ToolTip="Kit name (must be unique across the file)"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="ID:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding EditKitId, UpdateSourceTrigger=PropertyChanged}"
                                             Background="{DynamicResource SecondaryBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                             Padding="5,3" BorderThickness="1" BorderBrush="#555" Margin="0,3"
                                             ToolTip="Numeric kit ID (must be unique, auto-incremented when adding)"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding EditKitType, UpdateSourceTrigger=PropertyChanged}"
                                             Background="{DynamicResource SecondaryBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                             Padding="5,3" BorderThickness="1" BorderBrush="#555" Margin="0,3"
                                             ToolTip="KIT_TYPE_STANDARD or KIT_TYPE_REPLACED"/>

                                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,6,0,0">
                                        <Button Command="{Binding ApplyKitChangesCommand}" Content="Apply Changes"
                                                Width="110" Style="{StaticResource CommandButtonStyle}"
                                                ToolTip="Apply ID and type changes to the XML"/>
                                        <Button Command="{Binding RenameKitCommand}" Content="Rename"
                                                Width="70" Margin="8,0,0,0" Style="{StaticResource CommandButtonStyle}"
                                                ToolTip="Rename kit using the Name field above"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Stats summary -->
                        <Border Background="{DynamicResource DarkBgBrush}" CornerRadius="4" Padding="10" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Visible Mods:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding VisibleModCount}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Stat Mods:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding StatModCount}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Link Mods:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LinkModCount}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="11" Margin="0,2"/>
                            </Grid>
                        </Border>

                        <!-- Visible Mods list -->
                        <TextBlock Text="Visible Mods" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,5"/>
                        <ListBox ItemsSource="{Binding VisibleMods}"
                                 Background="{DynamicResource DarkBgBrush}"
                                 Foreground="{DynamicResource LightTextBrush}"
                                 MaxHeight="250"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11"
                                               Foreground="{DynamicResource LightTextBrush}" Padding="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource TertiaryBgBrush}" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource GrayTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
