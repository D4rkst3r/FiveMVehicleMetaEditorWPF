<UserControl x:Class="FiveMVehicleMetaEditorWPF.Views.Tabs.CarcolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource SecondaryBgBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding LoadCommand}" Content="📂 Load" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding SaveCommand}" Content="💾 Save" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding ExportCommand}" Content="📤 Export" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Separator Width="10"/>
                <TextBlock Text="{Binding CarcolEntries.Count}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text=" kits" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Left: Kit List -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SecondaryBgBrush}" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="🚨 Mod Kits" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="8,8,8,5"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding CarcolEntries}"
                         SelectedItem="{Binding SelectedEntry}"
                         Background="{DynamicResource DarkBgBrush}"
                         Foreground="{DynamicResource LightTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{DynamicResource LightTextBrush}" Padding="2" TextTrimming="CharacterEllipsis"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Kit Details -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SecondaryBgBrush}" Margin="5" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Empty state -->
                <StackPanel Grid.Row="0" Visibility="{Binding SelectedEntry, Converter={StaticResource BoolToVisInverseConverter}}">
                    <TextBlock Text="🚨 Carcols Editor" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10"/>
                    <TextBlock Text="Select a mod kit from the list to view its details."
                               FontSize="11" Foreground="{DynamicResource GrayTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Kit details -->
                <ScrollViewer Grid.Row="0" Grid.RowSpan="2"
                              Visibility="{Binding SelectedEntry, Converter={StaticResource BoolToVisConverter}}">
                    <StackPanel>
                        <!-- Kit name header -->
                        <TextBlock Text="{Binding SelectedEntry}" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                        <!-- Info grid -->
                        <Border Background="{DynamicResource DarkBgBrush}" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Kit ID:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding KitId}" Foreground="{DynamicResource LightTextBrush}" FontSize="11" Margin="0,2"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Kit Type:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding KitType}" Foreground="{DynamicResource LightTextBrush}" FontSize="11" Margin="0,2"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Visible Mods:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding VisibleModCount}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="11" Margin="0,2"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Stat Mods:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11" Margin="0,2"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding StatModCount}" Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" FontSize="11" Margin="0,2"/>
                            </Grid>
                        </Border>

                        <!-- Visible Mods list -->
                        <TextBlock Text="Visible Mods" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,6"/>
                        <ListBox ItemsSource="{Binding VisibleMods}"
                                 Background="{DynamicResource DarkBgBrush}"
                                 Foreground="{DynamicResource LightTextBrush}"
                                 MaxHeight="300"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="11"
                                               Foreground="{DynamicResource LightTextBrush}" Padding="2"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource TertiaryBgBrush}" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource GrayTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
