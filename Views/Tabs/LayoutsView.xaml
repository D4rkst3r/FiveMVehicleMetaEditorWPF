<UserControl x:Class="FiveMVehicleMetaEditorWPF.Views.Tabs.LayoutsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource SecondaryBgBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding LoadCommand}" Content="📂 Load" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding SaveCommand}" Content="💾 Save" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding ExportCommand}" Content="📤 Export" Width="80" Style="{StaticResource CommandButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Left: Layouts List -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SecondaryBgBrush}" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                         Padding="8" Margin="5" Height="30"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Layouts}"
                         SelectedItem="{Binding SelectedLayout}"
                         Background="{DynamicResource DarkBgBrush}"
                         Foreground="{DynamicResource LightTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding LayoutName}" FontWeight="Bold" Foreground="{DynamicResource LightTextBrush}"/>
                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource GrayTextBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Layout Editor -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SecondaryBgBrush}" Margin="5" Padding="15">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="Layout Properties" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>

                    <StackPanel Visibility="{Binding SelectedLayout, Converter={StaticResource BoolToVisConverter}}">
                        <!-- Layout Info Section -->
                        <TextBlock Text="Layout Information" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,15,0,10"/>

                        <Grid ColumnDefinitions="120,*" RowDefinitions="Auto,Auto">
                            <TextBlock Text="Name:" Foreground="{DynamicResource LightTextBrush}"/>
                            <TextBox Grid.Column="1" Text="{Binding LayoutName}" Background="{DynamicResource DarkBgBrush}"
                                     Foreground="{DynamicResource LightTextBrush}" Padding="5" Margin="5,0"/>

                            <TextBlock Grid.Row="1" Text="Category:" Foreground="{DynamicResource LightTextBrush}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Category}" Background="{DynamicResource DarkBgBrush}"
                                     Foreground="{DynamicResource LightTextBrush}" Padding="5" Margin="5,5,5,0"/>
                        </Grid>

                        <!-- Seats Section -->
                        <TextBlock Text="Seats Configuration" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,15,0,10"/>
                        <TextBlock Text="{Binding SeatsList}" FontSize="11" Foreground="{DynamicResource LightTextBrush}"
                                   Padding="5" Background="{DynamicResource DarkBgBrush}" TextWrapping="Wrap"/>

                        <!-- Doors Section -->
                        <TextBlock Text="Doors Configuration" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,15,0,10"/>
                        <TextBlock Text="{Binding DoorsList}" FontSize="11" Foreground="{DynamicResource LightTextBrush}"
                                   Padding="5" Background="{DynamicResource DarkBgBrush}" TextWrapping="Wrap"/>

                        <!-- Flags Section -->
                        <TextBlock Text="Layout Flags" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,15,0,10"/>

                        <StackPanel>
                            <CheckBox Content="Has Roof" IsChecked="{Binding HasRoof}" Foreground="{DynamicResource LightTextBrush}" Margin="0,5"/>
                            <CheckBox Content="Has Trunk" IsChecked="{Binding HasTrunk}" Foreground="{DynamicResource LightTextBrush}" Margin="0,5"/>
                            <CheckBox Content="Has Hood" IsChecked="{Binding HasHood}" Foreground="{DynamicResource LightTextBrush}" Margin="0,5"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SelectedLayout, Converter={StaticResource BoolToVisInverseConverter}}">
                        <TextBlock Text="Select a layout to edit" FontSize="11" Foreground="{DynamicResource GrayTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource TertiaryBgBrush}" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource GrayTextBrush}"/>
        </Border>
    </Grid>
</UserControl>


