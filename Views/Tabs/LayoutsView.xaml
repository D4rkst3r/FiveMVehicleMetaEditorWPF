<UserControl x:Class="FiveMVehicleMetaEditorWPF.Views.Tabs.LayoutsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource SecondaryBgBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding LoadCommand}" Content="📂 Load" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding SaveCommand}" Content="💾 Save" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding ExportCommand}" Content="📤 Export" Width="80" Style="{StaticResource CommandButtonStyle}"/>
            </StackPanel>
        </Border>

        <!-- Left: Layouts List -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SecondaryBgBrush}" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                         Padding="8" Margin="5" Height="30"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Layouts}"
                         SelectedItem="{Binding SelectedLayout}"
                         Background="{DynamicResource DarkBgBrush}"
                         Foreground="{DynamicResource LightTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding LayoutName}" FontWeight="Bold" Foreground="{DynamicResource LightTextBrush}"/>
                                <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource GrayTextBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Layout Editor -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SecondaryBgBrush}" Margin="5" Padding="15">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="Anim Rate Set Properties" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10"/>

                    <!-- Nothing selected -->
                    <StackPanel Visibility="{Binding SelectedLayout, Converter={StaticResource BoolToVisInverseConverter}}">
                        <TextBlock Text="Select a layout entry to view and edit its animation rates." FontSize="11" Foreground="{DynamicResource GrayTextBrush}" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Selected -->
                    <StackPanel Visibility="{Binding SelectedLayout, Converter={StaticResource BoolToVisConverter}}">

                        <!-- Set Name / Category info -->
                        <TextBlock Text="Set Name" FontSize="10" Foreground="{DynamicResource GrayTextBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding LayoutName}" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,4"/>

                        <TextBlock Text="Category / Type" FontSize="10" Foreground="{DynamicResource GrayTextBrush}" Margin="0,0,0,2"/>
                        <TextBlock Text="{Binding Category}" FontSize="11" Foreground="{DynamicResource LightTextBrush}" Margin="0,0,0,15"/>

                        <!-- AnimRate table -->
                        <TextBlock Text="Animation Rate Values" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Column Headers -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Section"
                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Padding="5,4" FontSize="11"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="SP Rate"
                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Padding="5,4" FontSize="11" HorizontalAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="MP Rate"
                                       FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Padding="5,4" FontSize="11" HorizontalAlignment="Center"/>

                            <!-- Normal Entry -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Normal Entry"
                                       Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Padding="5,4" FontSize="11"/>
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding NormalEntrySP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>
                            <TextBox Grid.Row="1" Grid.Column="2"
                                     Text="{Binding NormalEntryMP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>

                            <!-- Combat Entry -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Combat Entry"
                                       Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Padding="5,4" FontSize="11"/>
                            <TextBox Grid.Row="2" Grid.Column="1"
                                     Text="{Binding AnimCombatEntrySP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>
                            <TextBox Grid.Row="2" Grid.Column="2"
                                     Text="{Binding AnimCombatEntryMP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>

                            <!-- Forced Entry -->
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Forced Entry"
                                       Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Padding="5,4" FontSize="11"/>
                            <TextBox Grid.Row="3" Grid.Column="1"
                                     Text="{Binding ForcedEntrySP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>
                            <TextBox Grid.Row="3" Grid.Column="2"
                                     Text="{Binding ForcedEntryMP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>

                            <!-- Normal Exit -->
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Normal Exit"
                                       Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Padding="5,4" FontSize="11"/>
                            <TextBox Grid.Row="4" Grid.Column="1"
                                     Text="{Binding NormalExitSP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>
                            <TextBox Grid.Row="4" Grid.Column="2"
                                     Text="{Binding NormalExitMP, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Width="80" Padding="5,3" Margin="2,2" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Layout Flags -->
                        <TextBlock Text="Layout Flags" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,18,0,8"/>
                        <StackPanel>
                            <CheckBox Content="Has Roof"  IsChecked="{Binding HasRoof}"  Foreground="{DynamicResource LightTextBrush}" Margin="0,4"/>
                            <CheckBox Content="Has Trunk" IsChecked="{Binding HasTrunk}" Foreground="{DynamicResource LightTextBrush}" Margin="0,4"/>
                            <CheckBox Content="Has Hood"  IsChecked="{Binding HasHood}"  Foreground="{DynamicResource LightTextBrush}" Margin="0,4"/>
                        </StackPanel>

                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource TertiaryBgBrush}" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource GrayTextBrush}"/>
        </Border>
    </Grid>
</UserControl>


