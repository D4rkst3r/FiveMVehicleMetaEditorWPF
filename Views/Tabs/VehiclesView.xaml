<UserControl x:Class="FiveMVehicleMetaEditorWPF.Views.Tabs.VehiclesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource SecondaryBgBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding LoadCommand}" Content="📂 Load" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding SaveCommand}" Content="💾 Save" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding ExportCommand}" Content="📤 Export" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Width="1"/>
                <TextBlock Text="{Binding VehicleCount}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"/>
                <TextBlock Text="vehicles loaded" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Left: Vehicle List -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SecondaryBgBrush}" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <!-- Search -->
                <TextBox Grid.Row="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                         Padding="8" Margin="5" Height="30"/>
                <!-- Vehicle List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding FilteredVehicles}"
                         SelectedItem="{Binding SelectedVehicle}"
                         Background="{DynamicResource DarkBgBrush}"
                         Foreground="{DynamicResource LightTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding ModelName}" FontWeight="Bold" Foreground="{DynamicResource LightTextBrush}"/>
                                <TextBlock Text="{Binding VehicleMakeName}" FontSize="10" Foreground="{DynamicResource GrayTextBrush}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Vehicle Properties -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SecondaryBgBrush}" Margin="5" Padding="15">
            <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="Vehicle Properties" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}"/>

                    <StackPanel Visibility="{Binding SelectedVehicle, Converter={StaticResource BoolToVisConverter}}">
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Model:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding SelectedVehicle.ModelName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Make:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding SelectedVehicle.VehicleMakeName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Class:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedVehicle.VehicleClass, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Type:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedVehicle.VehicleType, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Seats:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SelectedVehicle.Seats, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Handling ID:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SelectedVehicle.HandlingId, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Game Name:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SelectedVehicle.GameName, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Vehicle Type:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SelectedVehicle.VehicleType, UpdateSourceTrigger=PropertyChanged}"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>

                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Layout:" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center" Margin="0,3"/>
                            <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SelectedVehicle.Layout}"
                                     IsReadOnly="True"
                                     Background="{DynamicResource DarkBgBrush}" Foreground="{DynamicResource LightTextBrush}"
                                     Padding="5,3" BorderThickness="1" BorderBrush="#444" Margin="0,3"/>
                        </Grid>

                        <Separator Margin="0,10"/>

                        <TextBlock Text="Flags" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource PrimaryBrush}" Margin="0,5"/>
                        <ListBox ItemsSource="{Binding SelectedVehicle.Flags}"
                                 Background="{DynamicResource DarkBgBrush}"
                                 Foreground="{DynamicResource LightTextBrush}"
                                 Height="100"/>
                    </StackPanel>

                    <StackPanel Visibility="{Binding SelectedVehicle, Converter={StaticResource BoolToVisInverseConverter}}">
                        <TextBlock Text="Select a vehicle to view properties" FontSize="11" Foreground="{DynamicResource GrayTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Status -->
        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Background="{StaticResource TertiaryBgBrush}" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource GrayTextBrush}"/>
        </Border>
    </Grid>
</UserControl>

