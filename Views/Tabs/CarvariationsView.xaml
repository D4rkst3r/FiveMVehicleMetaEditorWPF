<UserControl x:Class="FiveMVehicleMetaEditorWPF.Views.Tabs.CarvariationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource SecondaryBgBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding LoadCommand}" Content="📂 Load" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding SaveCommand}" Content="💾 Save" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Button Command="{Binding ExportCommand}" Content="📤 Export" Width="80" Style="{StaticResource CommandButtonStyle}"/>
                <Separator Width="10"/>
                <TextBlock Text="{Binding Variations.Count}" Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text=" vehicles" Foreground="{DynamicResource LightTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Left: Vehicle List -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource SecondaryBgBrush}" Margin="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="🎨 Vehicle Models" FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="8,8,8,5"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Variations}"
                         SelectedItem="{Binding SelectedVariation}"
                         Background="{DynamicResource DarkBgBrush}"
                         Foreground="{DynamicResource LightTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding}" Foreground="{DynamicResource LightTextBrush}" Padding="2"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- Right: Info Panel -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource SecondaryBgBrush}" Margin="5" Padding="15">
            <StackPanel>
                <TextBlock Text="🎨 Carvariations Editor" FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,10"/>

                <!-- When nothing selected -->
                <StackPanel Visibility="{Binding SelectedVariation, Converter={StaticResource BoolToVisInverseConverter}}">
                    <TextBlock Text="Select a vehicle from the list to view its variation data."
                               FontSize="11" Foreground="{DynamicResource GrayTextBrush}" TextWrapping="Wrap"/>
                </StackPanel>

                <!-- When selected -->
                <StackPanel Visibility="{Binding SelectedVariation, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="Selected Vehicle:" Foreground="{DynamicResource GrayTextBrush}" FontSize="11"/>
                    <TextBlock Text="{Binding SelectedVariation}" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,3,0,15"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource LightTextBrush}" FontSize="11"
                               Text="This vehicle's color indices and livery settings are stored in the carvariations.meta file. Load and Save to modify the file."/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{StaticResource TertiaryBgBrush}" Padding="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource GrayTextBrush}"/>
        </Border>
    </Grid>
</UserControl>
